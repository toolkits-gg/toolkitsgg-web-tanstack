# ========================================
# Database Configuration
# ========================================
# PostgreSQL connection string for local development with Docker
# If using the local Docker PostgreSQL setup (pnpm db:local:start), use:
DATABASE_URL="postgresql://toolkitsgg:toolkitsgg_dev_password@localhost:5432/toolkitsgg_db"
# For production or other database providers, replace with your connection string

# ========================================
# Authentication Configuration
# ========================================
# IMPORTANT: Generate a secure random secret for production
# You can generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Should match VITE_APP_URL
BETTER_AUTH_URL="http://localhost:3000"

# ========================================
# Application Configuration
# ========================================
# In production, this should be set to "production"
NODE_ENV=production

# Disable background jobs in development (run manually for testing)
# Set to true for production
ENABLE_BACKGROUND_JOBS=false

# ========================================
# Next.js Configuration
# ========================================
VITE_APP_URL=http://localhost:3000
# The toolkits.gg public cloudfront is default
VITE_CLOUDFRONT_URL="https://d1ig3kkc8hj9hz.cloudfront.net"

# ========================================
# Third-Party API Keys
# ========================================
# Discord OAauth
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# ImageKit 
IMAGEKIT_CLIENT_ID=""
IMAGEKIT_CLIENT_SECRET=""
IMAGEKIT_ENDPOINT_URL=""
# Resend
RESEND_KEY=""