{
  "name": "toolkitsgg-web-tanstack",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "post-cta-init": "npx -y create-db@latest --user-agent tanstack/tsrouter",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:local:start": "docker compose -f compose.local.yaml up -d",
    "db:local:stop": "docker compose -f compose.local.yaml stop",
    "db:local:restart": "docker compose -f compose.local.yaml restart",
    "db:local:down": "docker compose -f compose.local.yaml down -v",
    "favicons:generate": "gulp generateFavicons"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "1.6.5",
    "@faker-js/faker": "10.3.0",
    "@fontsource/geist": "5.2.8",
    "@mantine/carousel": "9.0.2",
    "@mantine/code-highlight": "9.0.2",
    "@mantine/core": "9.0.2",
    "@mantine/dates": "9.0.2",
    "@mantine/hooks": "9.0.2",
    "@mantine/modals": "9.0.2",
    "@mantine/notifications": "9.0.2",
    "@mantine/spotlight": "9.0.2",
    "@mantine/tiptap": "9.0.2",
    "@paralleldrive/cuid2": "3.3.0",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@react-email/components": "1.0.12",
    "@react-email/ui": "6.0.0",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-store": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/react-virtual": "3.13.24",
    "@tanstack/router-plugin": "1.132.0",
    "@tanstack/store": "latest",
    "@tiptap/extension-link": "3.22.3",
    "@tiptap/pm": "3.22.3",
    "@tiptap/react": "3.22.3",
    "@tiptap/starter-kit": "3.22.3",
    "better-auth": "1.5.3",
    "dayjs": "1.11.20",
    "dotenv": "17.4.2",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "idb": "8.0.3",
    "modern-screenshot": "4.7.0",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prisma": "7.4.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "recharts": "3.8.1",
    "resend": "6.12.0",
    "zod": "4.3.6"
